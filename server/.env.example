PORT=3001
DB_DIALECT=postgres
DB_HOST=/tmp
DB_PORT=5432
DB_NAME=meat
DB_USER=bayakaa
DB_PASSWORD=

# If connection fails, set your PostgreSQL password:
# DB_PASSWORD=your_password
#
# macOS (Postgres.app): DB_HOST=/tmp
# Linux / production:   DB_HOST=127.0.0.1

# Cloudinary (product images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=meat/products

# Comma-separated storefront/admin origins for CORS
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
